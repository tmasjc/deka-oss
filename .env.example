# Copy this file to `.env` at the repo root and fill in the values.
# `.env` is gitignored; `load_dotenv(override=False)` is called at every
# entry point (TUI, anchor, extraction) so shell exports still win.

# --- Required ---
# OpenRouter API key — consumed by the reflection agent and span extractor
# via the api_key_env setting in the unified config.yaml.
OPENROUTER_API_KEY=

# --- Required when refine.judge_api_key_env=VLLM_API_KEY ---
# vLLM without --api-key accepts any non-empty Bearer header, so any
# opaque value works. Keeps the real DashScope/OpenRouter key from
# being sent to the vLLM endpoint.
VLLM_API_KEY=vllm-no-auth

# --- Optional endpoint overrides ---
# Take precedence over config.yaml. Leave commented to use the YAML values.
# DEKA_EMBED_URL=http://localhost:8000
# DEKA_MILVUS_URI=http://localhost:19530
# Note: the Milvus collection is no longer configurable via env var —
# every scope in scopes.yaml declares its own ``milvus_collection``
# and ``postgres_table``, and the session picker chooses among them.

# Postgres DSN for the original-content lookup. Overrides the
# `postgres.dsn` value in config.yaml. The Postgres table is sourced
# per-session from the chosen scope's ``postgres_table``.
# DEKA_POSTGRES_DSN=postgresql://user:pass@localhost:5432/pipeline
